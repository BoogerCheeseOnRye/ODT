# TEoAAAG Storage & Path Configuration
# EVERYTHING on E: drive. NO external paths. Standalone setup.

## Primary Paths
PROJECT_ROOT=E:\
GAME_DIR=E:\TEoAAAG
TRIBES_DIR=E:\Tribes
BUILDS_DIR=E:\old-builds

## Models & AI
MODELS_DIR=E:\models
HERMES_AGENT=E:\hermes\hermes-agent
QWEN_MODEL=E:\models\Qwen_Qwen3.5-9B-Q4_K_M.gguf
OLLAMA_MODELS=E:\ollama-models
OLLAMA_HOST=localhost:11434

## Development Tools
BUILD_TOOLS=E:\BuildTools
MINGW_BIN=E:\BuildTools\MinGW\bin
NODE_PROXY=E:\proxy.js
DOCKER_COMPOSE=E:\docker-compose.yml

## Storage & Logging
INPUT_LOGS=E:\input_logs
STORAGE_LOGS=E:\logs
CODE_CONFIG=E:\code-server-config
DOCKER_DATA=E:\docker-data

## Web UI
DASHBOARD=E:\dashboard.html
DASHBOARD_PORT=9001

## Standalone Services
PROXY_PORT=9001
PROXY_TARGET=http://localhost:11434

## NO EXTERNAL PATHS
# Everything is self-contained on E: drive
# No T:\, no D:\, no external dependencies
# Fully offline-capable, fully portable
