# TEoAAAG Environment Configuration
# Models stay SEPARATE from app. Everything on E:\ drive.

# Dashboard Server
DASHBOARD_PORT=8080

# Proxy Server
PROXY_PORT=9001

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODELS_DIR=C:\odt-data\models
OLLAMA_DATA_DIR=C:\odt-data\cache

# Model Paths (must be on selected drive)
MODELS_DIR=C:\odt-data\models
CACHE_DIR=C:\odt-data\cache

# App Security
APP_DIR=E:\dashboard-appv2
ALLOWED_PATHS=C:\odt-data;D:\odt-data;E:\odt-data

# Features
ENABLE_NETWORK_MODE=true
ENABLE_HARDWARE_DETECTION=true
ENABLE_DIAGNOSTICS=true
CORS_ENABLED=true
