# ODT Configuration
# Edit these values to customize your setup
# No coding required - just change the values!

# Ollama settings
OLLAMA_HOST=http://localhost:11434

# Proxy server settings  
PROXY_HOST=http://localhost:8080

# Default model to use (run 'ollama list' to see available models)
MODEL=qwen2.5-1.5b

# Path to scan for GGUF model files
MODELS_PATH=E:\ollama-models

# Note: Changes to hosts require restarting the proxy (npm start)